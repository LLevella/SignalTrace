{
  "name": "@llewella/signal-trace",
  "version": "0.1.2",
  "description": "Tiny canvas charts for live signals with legacy Knockout support.",
  "license": "MIT",
  "author": "Irina <38900844+LLevella@users.noreply.github.com>",
  "type": "commonjs",
  "main": "./dist/draw.cjs",
  "module": "./dist/draw.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/draw.mjs",
      "require": "./dist/draw.cjs"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chart-core.mjs",
      "require": "./dist/chart-core.cjs"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./web-component.mjs"
    },
    "./adapters/react": {
      "types": "./dist/adapters.d.ts",
      "import": "./adapters/react.mjs"
    },
    "./adapters/vue": {
      "types": "./dist/adapters.d.ts",
      "import": "./adapters/vue.mjs"
    },
    "./adapters/svelte": {
      "types": "./dist/adapters.d.ts",
      "import": "./adapters/svelte.mjs"
    },
    "./legacy/amd/draw": "./draw.js",
    "./legacy/amd/core": "./chart-core.js",
    "./legacy/amd/knockout": "./ko.draw.js"
  },
  "files": [
    "dist",
    "docs",
    "adapters",
    "examples",
    "chart-core.js",
    "draw.js",
    "web-component.mjs",
    "ko.draw.js",
    "template.html",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "audit:prod": "npm audit --omit=dev",
    "build": "node scripts/build-modern.js",
    "check": "npm test && npm run build && node --check dist/chart-core.cjs && node --check dist/draw.cjs",
    "test": "node test/chart-core.test.js && node test/draw.test.js",
    "test:e2e": "playwright test",
    "test:unit": "npm run build && vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "canvas",
    "chart",
    "time-series",
    "knockout",
    "monitoring"
  ],
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "typescript": "6.0.3",
    "vite": "5.4.21",
    "vitest": "1.6.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LLevella/SignalTrace.git"
  },
  "bugs": {
    "url": "https://github.com/LLevella/SignalTrace/issues"
  },
  "homepage": "https://github.com/LLevella/SignalTrace#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
